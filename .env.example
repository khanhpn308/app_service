APP_NAME=IoT Backend API
ENVIRONMENT=prod
CORS_ORIGINS=http://localhost

# External database endpoint (independent database_service deployment)
# If running via Docker (shared network), use the DB service name, e.g. "db"
DB_HOST=db
DB_PORT=3306
DB_USER=iot_user
DB_PASSWORD=CHANGE_ME_APP_PASSWORD
DB_NAME=iot

# Frontend published URL (for clients and reverse proxies)
API_URL=http://localhost:8000
FRONTEND_HTTP_PORT=80

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# MQTT subscriber (Mosquitto)
MQTT_ENABLED=true
MQTT_HOST=mosquitto
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_CLIENT_ID=iot-backend-subscriber
MQTT_KEEPALIVE=60
MQTT_TOPICS=devices/+/telemetry
MQTT_QOS=0
MQTT_MAX_MESSAGES=500

# External InfluxDB endpoint (independent influxdb_service deployment)
# If running via Docker shared network, keep service name "influxdb"
INFLUX_ENABLED=true
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=CHANGE_ME_INFLUX_TOKEN
INFLUX_ORG=iot
INFLUX_BUCKET=iot_telemetry
INFLUX_MEASUREMENT=sensor_readings

# Frontend WS URL (optional). Leave empty to auto-resolve from current origin.
VITE_WS_URL=
