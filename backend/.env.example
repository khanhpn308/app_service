ENVIRONMENT=dev
APP_NAME=IoT Backend API
# Comma-separated list
CORS_ORIGINS=http://localhost:3000

# Database server routing (remote DB host/IP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=iot

# JWT (login session)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# MQTT subscriber (Mosquitto)
MQTT_ENABLED=true
MQTT_HOST=localhost
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_CLIENT_ID=iot-backend-subscriber
MQTT_KEEPALIVE=60
# Comma-separated list; edit later
MQTT_TOPICS=test/topic1,test/topic2
MQTT_QOS=0
MQTT_MAX_MESSAGES=500

