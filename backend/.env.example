ENVIRONMENT=dev
APP_NAME=IoT Backend API
# Comma-separated list
CORS_ORIGINS=http://localhost:3000

# Database server routing
# Same machine / shared Docker network: use the service name from database_service ("db")
# Different machine / remote MySQL server: use IP address or DNS name
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=iot

# JWT (login session)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# MQTT subscriber (Mosquitto)
MQTT_ENABLED=true
MQTT_HOST=localhost
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_CLIENT_ID=iot-backend-subscriber
MQTT_KEEPALIVE=60
# Comma-separated list; edit later
MQTT_TOPICS=test/topic1,test/topic2
MQTT_QOS=0
MQTT_MAX_MESSAGES=500

# InfluxDB (time-series storage)
# In Docker shared network, use service name from influxdb stack (e.g. "influxdb")
INFLUX_ENABLED=true
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=CHANGE_ME_INFLUX_TOKEN
INFLUX_ORG=iot
INFLUX_BUCKET=iot_telemetry
INFLUX_MEASUREMENT=sensor_readings

